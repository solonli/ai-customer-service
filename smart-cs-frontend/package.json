{
  "name": "smart-cs-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "智能客服系统前端",
  "scripts": {
    "dev:user-chat": "pnpm --filter @smartcs/user-chat dev",
    "dev:agent-workspace": "pnpm --filter @smartcs/agent-workspace dev",
    "dev:admin-console": "pnpm --filter @smartcs/admin-console dev",
    "build:user-chat": "pnpm --filter @smartcs/user-chat build",
    "build:agent-workspace": "pnpm --filter @smartcs/agent-workspace build",
    "build:admin-console": "pnpm --filter @smartcs/admin-console build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
